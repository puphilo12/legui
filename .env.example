# =====================================================================
# LEGUI — variables de entorno
# Copiá este archivo a ".env" y completá los valores.
# Si NO completás Supabase, la app corre en MODO MOCK (datos de ejemplo
# en el navegador), perfecto para desarrollar el look y la UX.
# =====================================================================

# --- Supabase (dejar vacío para modo mock) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Identificador de tienda (multi-tienda estilo BV) ---
VITE_STORE_ID=legui

# --- MercadoPago ---
VITE_MP_PUBLIC_KEY=          # Public key de tu cuenta MP
VITE_MP_SANDBOX=true         # true = credenciales de prueba, false = producción

# --- Variables SERVER-SIDE (solo en Vercel, nunca en .env local) ---
# MP_ACCESS_TOKEN=           # Access Token de MP (secreto, no empieza con VITE_)
# APP_URL=                   # URL de producción, ej: https://legui.vercel.app
# SUPABASE_URL=              # Igual que VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY= # Service role key de Supabase (secreto)
